---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

interface Props {
    currentCategory?: string;
}

const { currentCategory } = Astro.props;
const showSidebar = !!currentCategory;
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta
            name="description"
            content="Side-by-side comparison of AI agent framework syntax across OpenAI, Anthropic, Gemini, Pydantic AI, LangGraph, Mastra, and AI SDK"
        />
        <meta property="og:title" content="Agent Party" />
        <meta
            property="og:description"
            content="Side-by-side comparison of AI agent framework syntax across OpenAI, Anthropic, Gemini, Pydantic AI, LangGraph, Mastra, and AI SDK"
        />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://agent.party" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content="Agent Party" />
        <meta
            name="twitter:description"
            content="Side-by-side comparison of AI agent framework syntax across OpenAI, Anthropic, Gemini, Pydantic AI, LangGraph, Mastra, and AI SDK"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>Agent Party</title>
        {gaId && (
            <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
            <script define:vars={{ gaId }}>
                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());
                gtag('config', gaId);
            </script>
        )}
        <script is:inline>
            (function(){var t=localStorage.getItem('agent-party-theme');if(t==='light')document.documentElement.setAttribute('data-theme','light')})();
        </script>
        <ViewTransitions />
    </head>
    <body class="bg-[var(--bg-body)] text-[var(--text-primary)] min-h-screen">
        <Header />
        <div class="flex">
            {showSidebar && <Sidebar currentSlug={currentCategory} />}
            <main class="flex-1 min-w-0">
                <slot />
            </main>
        </div>
    </body>
</html>
