---
const githubUrl = "https://github.com/mirableio/agent-party";
---

<header class="border-b border-[var(--border-primary)]">
    <div class="flex items-center justify-between px-4 lg:px-6 py-3">
        <a
            id="home-link"
            href="/"
            class="flex items-center gap-2 text-lg font-bold hover:text-[var(--text-primary)]"
        >
            <div class="pr-1">🤖</div>
            Agent Party
        </a>
        <div class="flex items-center gap-5">
            <a
                href="/about"
                class="text-sm text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors"
                >About</a
            >
            <a
                href={githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded border border-[var(--border-secondary)] bg-[var(--github-btn-bg)] px-3 py-1 text-sm text-[var(--text-primary)] hover:opacity-90 transition-opacity"
                aria-label="View on GitHub"
            >
                <svg
                    class="w-4 h-4"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path
                        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                    ></path>
                </svg>
                <span class="hidden sm:inline">View on GitHub</span>
            </a>
            <button
                id="theme-toggle"
                class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors cursor-pointer"
                aria-label="Toggle theme"
            >
                <!-- Sun icon (shown in dark mode) -->
                <svg
                    class="w-4 h-4 theme-icon-sun"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <circle cx="12" cy="12" r="5" />
                    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
                </svg>
                <!-- Moon icon (shown in light mode) -->
                <svg
                    class="w-4 h-4 theme-icon-moon hidden"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
            </button>
        </div>
    </div>
</header>

<script>
    function setupHomeReset() {
        const homeLink = document.getElementById("home-link") as HTMLAnchorElement | null;
        if (!homeLink) return;
        if (homeLink.dataset.resetBound === "1") return;
        homeLink.dataset.resetBound = "1";

        homeLink.addEventListener("click", () => {
            localStorage.removeItem("agent-party-selected");
        });
    }

    function syncThemeIcons() {
        const isLight = document.documentElement.getAttribute("data-theme") === "light";
        document.querySelectorAll(".theme-icon-sun").forEach((el) => {
            (el as HTMLElement).classList.toggle("hidden", isLight);
        });
        document.querySelectorAll(".theme-icon-moon").forEach((el) => {
            (el as HTMLElement).classList.toggle("hidden", !isLight);
        });
    }

    function setupThemeToggle() {
        const btn = document.getElementById("theme-toggle");
        if (!btn) return;
        if (btn.dataset.themeBound === "1") return;
        btn.dataset.themeBound = "1";

        btn.addEventListener("click", () => {
            const isLight = document.documentElement.getAttribute("data-theme") === "light";
            if (isLight) {
                document.documentElement.removeAttribute("data-theme");
                localStorage.setItem("agent-party-theme", "dark");
            } else {
                document.documentElement.setAttribute("data-theme", "light");
                localStorage.setItem("agent-party-theme", "light");
            }
            syncThemeIcons();
        });

        syncThemeIcons();
    }

    setupHomeReset();
    setupThemeToggle();
    document.addEventListener("astro:after-swap", () => {
        // Re-apply theme — ViewTransitions replaces <html> attrs from the new page
        const theme = localStorage.getItem("agent-party-theme");
        if (theme === "light") {
            document.documentElement.setAttribute("data-theme", "light");
        } else {
            document.documentElement.removeAttribute("data-theme");
        }
        setupHomeReset();
        setupThemeToggle();
    });
</script>
