---
import type { FrameworkDef } from "../data/frameworks";

interface SnippetFile {
  filename: string;
  language: string;
  code: string;
  html: string;
}

interface Props {
  framework: FrameworkDef;
  files: SnippetFile[];
}

const { framework, files } = Astro.props;
const cardId = `snippet-${framework.id}-${Math.random().toString(36).slice(2, 8)}`;
---

<div data-framework={framework.id} class="max-w-2xl">
  <h3 class="text-sm font-medium mb-2 text-[var(--text-secondary)] flex items-center gap-1.5">
    <img
      src={framework.logoPath}
      alt=""
      class:list={[
        "w-4 h-4 object-contain",
        framework.logoStyle && "invert-on-dark",
      ]}
      style={framework.logoStyle}
    />
    {framework.name}
  </h3>
  <div class="snippet-card" id={cardId}>
    <div class="flex space-x-1 overflow-x-auto">
      {files.map((file, i) => (
        <button
          class:list={[
            "snippet-tab border border-[var(--code-border)] border-b-0 py-1.5 px-3 text-xs rounded-t shrink-0 cursor-pointer",
            i === 0 ? "snippet-tab-active" : "snippet-tab-inactive",
          ]}
          data-tab-index={i}
        >
          {file.filename.replace(/^\d+-/, "")}
        </button>
      ))}
    </div>
    {
      files.map((file, i) => (
        <div
          class:list={[
            "snippet-panel relative group",
            i > 0 && "hidden",
          ]}
          data-panel-index={i}
          data-code={file.code.trim()}
        >
          <button
            class="copy-btn absolute top-2 right-2 z-10 p-1.5 rounded bg-[var(--bg-surface-hover)] text-[var(--text-muted)] hover:text-[var(--text-primary)] opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer"
            aria-label="Copy code"
          >
            <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke-width="2" />
            </svg>
            <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </button>
          <div
            class="bg-[var(--code-bg)] border border-[var(--code-border)] overflow-auto rounded-b rounded-tr text-sm [&_pre]:!bg-transparent [&_pre]:!p-4 [&_pre]:!pt-2 [&_pre]:!m-0"
            set:html={file.html}
          />
        </div>
      ))
    }
  </div>
</div>

<script>
  function setupTabs() {
    document.querySelectorAll<HTMLElement>(".snippet-card").forEach((card) => {
      const tabs = card.querySelectorAll<HTMLElement>(".snippet-tab");
      const panels = card.querySelectorAll<HTMLElement>(".snippet-panel");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const idx = tab.dataset.tabIndex;
          tabs.forEach((t) => {
            const isActive = t.dataset.tabIndex === idx;
            t.classList.toggle("snippet-tab-active", isActive);
            t.classList.toggle("snippet-tab-inactive", !isActive);
          });
          panels.forEach((p) =>
            p.classList.toggle("hidden", p.dataset.panelIndex !== idx),
          );
        });
      });
    });
  }

  function setupCopy() {
    document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const panel = btn.closest<HTMLElement>(".snippet-panel");
        if (!panel) return;
        const code = panel.dataset.code || "";
        await navigator.clipboard.writeText(code);
        const copyIcon = btn.querySelector(".copy-icon") as HTMLElement;
        const checkIcon = btn.querySelector(".check-icon") as HTMLElement;
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 1500);
      });
    });
  }

  setupTabs();
  setupCopy();
  document.addEventListener("astro:after-swap", () => {
    setupTabs();
    setupCopy();
  });
</script>
